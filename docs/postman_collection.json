{
  "info": {
    "name": "Smart Leads Dashboard API",
    "description": "Complete API documentation for the Smart Leads Dashboard — a MERN stack lead management application with JWT authentication and role-based access control.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "Check if the API server is running."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Test123!\",\n  \"role\": \"sales\"\n}"
            },
            "description": "Register a new user. Role can be 'admin' or 'sales' (defaults to 'sales')."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@smartleads.com\",\n  \"password\": \"Admin123!\"\n}"
            },
            "description": "Login with email and password. Returns JWT token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "Get All Leads (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/leads?page=1&limit=10&sortBy=latest",
              "host": ["{{baseUrl}}"],
              "path": ["leads"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sortBy", "value": "latest" },
                { "key": "status", "value": "", "disabled": true },
                { "key": "source", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Get paginated leads with optional filters: status, source, search, sortBy."
          }
        },
        {
          "name": "Get All Leads (Filtered)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/leads?status=Qualified&source=Instagram&search=Rahul&sortBy=latest&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["leads"],
              "query": [
                { "key": "status", "value": "Qualified" },
                { "key": "source", "value": "Instagram" },
                { "key": "search", "value": "Rahul" },
                { "key": "sortBy", "value": "latest" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Example showing all filters working together."
          }
        },
        {
          "name": "Get Lead by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/leads/:id",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Get a single lead's full details by their ID."
          }
        },
        {
          "name": "Create Lead",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/leads",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rahul Sharma\",\n  \"email\": \"rahul@example.com\",\n  \"status\": \"New\",\n  \"source\": \"Website\"\n}"
            },
            "description": "Create a new lead. Validated with Zod schema."
          }
        },
        {
          "name": "Update Lead",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/leads/:id",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Contacted\",\n  \"source\": \"Instagram\"\n}"
            },
            "description": "Update an existing lead. At least one field must be provided."
          }
        },
        {
          "name": "Delete Lead (Admin Only)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/leads/:id",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Delete a lead. Requires admin role."
          }
        },
        {
          "name": "Export Leads CSV",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/leads/export/csv",
              "host": ["{{baseUrl}}"],
              "path": ["leads", "export", "csv"],
              "query": [
                { "key": "status", "value": "", "disabled": true },
                { "key": "source", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Export leads as a CSV file. Supports same filters as the list endpoint."
          }
        }
      ]
    }
  ]
}
